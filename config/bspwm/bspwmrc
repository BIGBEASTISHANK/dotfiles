#! /bin/sh

## BSPWM Config
bspc monitor eDP-1 -d ’é¼ ’ĆŁ ’äĀ ’äĪ Ņüē ’ÄÆ ’äø ’ł│ ’ĆĮ
bspc monitor HDMI-1-0 -d ’é¼ ’ĆŁ ’äĀ ’äĪ Ņüē ’ÄÆ ’äø ’ł│ ’ĆĮ

## Set initial border color
bspc config normal_border_color "#515860"
bspc config active_border_color "#FF69B4"
bspc config focused_border_color "#1793D1"
bspc config presel_feedback_color "#3AB1F5"

bspc config border_width         4
bspc config window_gap          8

bspc config split_ratio          0.5

## Applications rule
# bspc rule -a "steam" desktop=^7
bspc rule -a "stacer" state=floating
bspc rule -a "scrcpy" state=floating
# bspc rule -a "Brave-browser" desktop=^1
bspc rule -a "Code" desktop=^4 follow=true
# bspc rule -a "Pcmanfm" desktop=^2 follow=true
bspc rule -a "discord" desktop=^6 follow=true
# bspc rule -a "VSCodium" desktop=^4 follow=true
bspc rule -a "Gnome-calculator" state=floating
# bspc rule -a "Alacritty" desktop=^3 follow=true
bspc rule -a "UnrealEditor" desktop=^5 follow=false
bspc rule -a "UE4Editor" desktop=^5 follow=false
bspc rule -a "com.github.sgpthomas.hourglass" state=floating
# bspc rule -a "Protonvpn-app" state=floating desktop=^8 follow=false
bspc rule -a "Protonvpn-app" state=floating
# bspc rule -a "SimpleScreenRecorder" state=floating desktop=^9 follow=true
bspc rule -a "SimpleScreenRecorder" state=floating
bspc rule -a "Signal" state=floating
bspc rule -a "unityhub" state=floating
bspc rule -a "org-tlauncher-tlauncher-rmo-TLauncher" state=floating desktop=^7





##----------------##
## System Startup ##
##----------------##
xrandr \
  --output eDP-1 --mode 2560x1600 --pos 2560x0 \
  --output HDMI-1-0 --mode 2560x1440 --pos 0x160

pkill sxhkd
sxhkd &

huionH1060PKeySetup &

pkill protonvpn-app
protonvpn-app &

pkill picom
picom &

pkill dunst
dunst &

xsetroot -cursor_name left_ptr &

pkill -f /usr/lib/xfce-polkit/xfce-polkit
/usr/lib/xfce-polkit/xfce-polkit &

pkill -f $HOME/.config/dunst/batteryStatus
$HOME/.config/dunst/batteryStatus &

nitrogen --restore &

pkill xss-lock
xss-lock --transfer-sleep-lock -- \
    sh -c 'betterlockscreen -l blur; pkill -USR1 xss-lock' &

xinput set-prop "Compx 2.4G Wireless Receiver" "libinput Accel Profile Enabled" 0 1 0
xinput set-prop "CUST0001:01 04F3:3282 Touchpad" "libinput Natural Scrolling Enabled" 1
xinput set-prop "CUST0001:01 04F3:3282 Touchpad" "libinput Tapping Enabled" 1
xinput set-prop "CUST0001:01 04F3:3282 Touchpad" "libinput Disable While Typing Enabled" 1

##------------##
## Essentials ##
##------------##
pkill polybar
MONITOR=eDP-1 polybar main &
MONITOR=HDMI-1-0 polybar main &

pkill nm-applet
nm-applet &

pkill greenclip
greenclip daemon &

pkill -f optimus-manager-qt
optimus-manager-qt &

##-------------##
## Application ##
##-------------##
pkill Discord
discord --start-minimized &

pkill signal-desktop
signal-desktop &

pkill anytype
anytype &
